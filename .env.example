# =============================================================================
# GR-Review Configuration Template
# =============================================================================
# COPY this file to .env and fill in your values
# cp .env.example .env
#
# IMPORTANT: Never commit .env file! It's already in .gitignore
# =============================================================================

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Supported providers: openai, anthropic, google, zhipuai, azure_openai, ollama, custom
LLM_PROVIDER=zhipuai

# API Key - get from your LLM provider's dashboard
# Can also use environment-specific vars:
# - OPENAI_API_KEY
# - ANTHROPIC_API_KEY
# - GOOGLE_API_KEY
# - ZHIPUAI_API_KEY
# - AZURE_OPENAI_API_KEY
# - CUSTOM_API_KEY
LLM_API_KEY=

# Model name (provider-specific):
# - openai: gpt-4, gpt-3.5-turbo
# - anthropic: claude-3-opus-20240229, claude-3-sonnet-20240229
# - google: gemini-pro, gemini-pro-vision
# - zhipuai: glm-4-flash, glm-4
# - azure_openai: your deployment name
# - ollama: llama2, mistral, codellama
LLM_MODEL=glm-4-flash

# Base URL (only for custom providers or self-hosted)
# Leave empty for default provider endpoints
LLM_BASE_URL=

# =============================================================================
# GitHub Configuration
# =============================================================================
# GitHub Personal Access Token with repo scope
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Repository in "owner/repo" format
GITHUB_REPOSITORY=owner/repo

# Pull Request number to review
GITHUB_PR_NUMBER=1

# =============================================================================
# Execution Mode
# =============================================================================
# parallel  - Run all agents simultaneously (faster, higher cost)
# sequential - Run agents one by one (slower, lower cost)
# adaptive  - Smart routing based on PR complexity (recommended)
EXECUTION_MODE=adaptive

# =============================================================================
# Linter Configuration (Optional)
# =============================================================================
# Command to run for linting. Set to empty to skip.
LINTER_COMMAND=eslint
SKIP_LINTER=false

# =============================================================================
# CI Provider Configuration (Optional)
# =============================================================================
# Supported: github, gitlab, jenkins, teamcity, circleci, azure, none
CI_PROVIDER=github

# CI Status URL (for TeamCity, Jenkins, custom)
CI_STATUS_URL=

# CI API Token
CI_API_TOKEN=

# CI Build Config ID (TeamCity, Jenkins)
CI_BUILD_CONFIG=

# =============================================================================
# Token Optimization (Optional)
# =============================================================================
# Enable response caching to reduce costs
ENABLE_CACHING=true

# Maximum tokens to send in context (input)
MAX_CONTEXT_TOKENS=8000

# Enable smart truncation for large diffs
SMART_TRUNCATION=true

# =============================================================================
# Review Limits (Optional)
# =============================================================================
MAX_REVIEW_FILES=50
MAX_DIFF_CHARS=100000

# =============================================================================
# LLM Parameters (Optional)
# =============================================================================
TEMPERATURE=0.3
MAX_TOKENS=4096

# =============================================================================
# Logging (Optional)
# =============================================================================
# DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO